# Server Configuration
PORT=4000
NODE_ENV=development

# Database Connection
# Replace USERNAME, PASSWORD, and DATABASE_NAME with your PostgreSQL connection details
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduler_db?schema=public"

# Authentication Options
JWT_SECRET="super-secret-jwt-key"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# Worker Scheduling Parameters
WORKER_CONCURRENCY_LIMIT=10
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
REAPER_INTERVAL_MS=10000
